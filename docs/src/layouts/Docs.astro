---
import DocsSidebar from '../components/DocsSidebar.astro';
import { DOCS_NAV } from '../content/nav';
import { SITE } from '../lib/seo';
import Base from './Base.astro';

interface Props {
  title?: string;
  description?: string;
  eyebrow?: string;
  frontmatter?: { title?: string; description?: string; eyebrow?: string };
}
const props = Astro.props as Props;
const fm = props.frontmatter ?? {};
const title = props.title ?? fm.title ?? 'slotplate';
const description = props.description ?? fm.description ?? SITE.description;
const eyebrow = props.eyebrow ?? fm.eyebrow;
const pathname = Astro.url.pathname;

// Reconstruct the source-file path so each docs page gets an "Edit on GitHub"
// link. Astro only exposes file in dev — we reverse-engineer from pathname:
// `/docs/quickstart/` → `docs/src/pages/docs/quickstart.astro`. Pages that
// don't follow this convention (collection-rendered, etc.) can still set
// a `sourceFile` prop explicitly.
const cleaned = pathname.replace(/\/$/, '').replace(/^\//, '');
const sourceGuess = cleaned ? `docs/src/pages/${cleaned}.astro` : 'docs/src/pages/index.astro';
const editUrl = `https://github.com/schmooky/slotplate/edit/main/${sourceGuess}`;
---
<Base title={`${title} · ${SITE.name}`} description={description}>
  <div class="container grid gap-10 py-12 md:grid-cols-[240px_minmax(0,1fr)]">
    <DocsSidebar nav={DOCS_NAV} pathname={pathname} />
    <article class="prose-docs min-w-0 max-w-3xl animate-fade-in" data-pagefind-body>
      {eyebrow && (
        <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-primary">
          {eyebrow}
        </div>
      )}
      <h1 class="mb-6 text-4xl font-semibold tracking-tight">{title}</h1>
      {description && <p class="mb-8 text-lg text-muted-foreground">{description}</p>}
      <slot />

      <footer class="mt-16 flex flex-wrap items-center justify-between gap-3 border-t border-border/40 pt-6 text-xs text-muted-foreground">
        <a
          href={editUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 rounded-md border border-border/60 px-2.5 py-1 transition-colors hover:bg-secondary/60 hover:text-foreground"
        >
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
          </svg>
          Edit this page on GitHub
        </a>
        <span class="font-mono">{sourceGuess}</span>
      </footer>
    </article>
  </div>
</Base>
