---
// Finite state machine — default phases and the transitions between them.
---
<svg viewBox="0 0 900 460" class="w-full h-auto max-h-[540px]" role="img" aria-label="FSM state chart">
  <defs>
    <marker id="fsmArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="hsl(22 92% 52%)" />
    </marker>
    <linearGradient id="fsmActive" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="hsl(22 92% 52%)" />
      <stop offset="100%" stop-color="hsl(36 100% 50%)" />
    </linearGradient>
  </defs>

  <!-- IDLE -->
  <g>
    <circle cx="100" cy="230" r="56" fill="hsl(0 0% 100%)" stroke="hsl(22 92% 52%)" stroke-width="2.5" />
    <text x="100" y="226" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="hsl(22 92% 52%)">idle</text>
    <text x="100" y="246" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">waits for click</text>
  </g>

  <!-- Start marker -->
  <circle cx="30" cy="230" r="8" fill="hsl(20 20% 12%)" />
  <line x1="40" y1="230" x2="42" y2="230" stroke="hsl(20 20% 12%)" stroke-width="2" marker-end="url(#fsmArrow)" />

  <!-- SPIN -->
  <g>
    <circle cx="300" cy="110" r="60" fill="url(#fsmActive)" stroke="hsl(22 92% 45%)" stroke-width="2.5" />
    <text x="300" y="106" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="white">spin</text>
    <text x="300" y="126" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="white" opacity="0.9">debitBet + request</text>
  </g>

  <!-- STOPSPIN -->
  <g>
    <circle cx="540" cy="110" r="66" fill="url(#fsmActive)" stroke="hsl(22 92% 45%)" stroke-width="2.5" />
    <text x="540" y="104" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" font-weight="800" fill="white">stopSpin</text>
    <text x="540" y="124" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="white" opacity="0.9">reels land on grid</text>
  </g>

  <!-- WINSHOW -->
  <g>
    <circle cx="780" cy="230" r="60" fill="url(#fsmActive)" stroke="hsl(22 92% 45%)" stroke-width="2.5" />
    <text x="780" y="226" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" font-weight="800" fill="white">winShow</text>
    <text x="780" y="246" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="white" opacity="0.9">spotlight + credit</text>
  </g>

  <!-- Arrows -->
  <!-- idle -> spin -->
  <path d="M 147 205 Q 200 150 242 118" stroke="hsl(22 92% 52%)" stroke-width="2" fill="none" marker-end="url(#fsmArrow)" />
  <text x="175" y="155" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">click</text>

  <!-- spin -> stopSpin -->
  <line x1="361" y1="110" x2="474" y2="110" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#fsmArrow)" />
  <text x="417" y="100" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">response received</text>

  <!-- stopSpin -> winShow -->
  <path d="M 593 153 Q 650 185 733 205" stroke="hsl(22 92% 52%)" stroke-width="2" fill="none" marker-end="url(#fsmArrow)" />
  <text x="695" y="165" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">allLanded</text>

  <!-- winShow -> idle (long curve) -->
  <path d="M 736 265 Q 400 420 148 262" stroke="hsl(22 92% 52%)" stroke-width="2" fill="none" marker-end="url(#fsmArrow)" />
  <text x="440" y="395" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">win hold elapsed (or skip)</text>

  <!-- winShow -> idle shortcut (no winlines) -->
  <path d="M 726 205 Q 440 280 148 222" stroke="hsl(24 25% 70%)" stroke-width="1.5" fill="none" stroke-dasharray="4,4" marker-end="url(#fsmArrow)" />
  <text x="440" y="255" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">no winlines → idle immediately</text>

  <!-- Skip label on spin/stopSpin -->
  <text x="300" y="196" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="9.5" fill="hsl(22 92% 52%)">skip() = forceStop</text>
  <text x="540" y="200" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="9.5" fill="hsl(22 92% 52%)">skip() = forceStop</text>
  <text x="780" y="310" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="9.5" fill="hsl(22 92% 52%)">skip() = cancel hold</text>

  <!-- Legend -->
  <rect x="30" y="395" width="840" height="48" rx="8" fill="hsl(26 30% 96%)" stroke="hsl(24 25% 85%)" />
  <circle cx="56" cy="419" r="6" fill="hsl(0 0% 100%)" stroke="hsl(22 92% 52%)" stroke-width="2" />
  <text x="70" y="423" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">idle / resting phase</text>
  <circle cx="240" cy="419" r="6" fill="url(#fsmActive)" />
  <text x="254" y="423" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">active phase</text>
  <line x1="386" y1="419" x2="416" y2="419" stroke="hsl(22 92% 52%)" stroke-width="2" />
  <text x="425" y="423" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">normal transition</text>
  <line x1="560" y1="419" x2="590" y2="419" stroke="hsl(24 25% 70%)" stroke-width="1.5" stroke-dasharray="4,4" />
  <text x="599" y="423" font-family="ui-monospace, Menlo, monospace" font-size="11" fill="hsl(20 20% 12%)">conditional shortcut</text>
</svg>
