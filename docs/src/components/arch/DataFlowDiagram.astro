---
// Unidirectional cycle: input → FSM → state mutation → presenter observes → view → resolution → back to FSM.
---
<svg viewBox="0 0 820 460" class="w-full h-auto max-h-[520px]" role="img" aria-label="Unidirectional data flow">
  <defs>
    <marker id="flowArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="hsl(22 92% 52%)" />
    </marker>
  </defs>

  <!-- Nodes arranged in a loop -->
  <!-- 1. Input (HUD click) -->
  <g>
    <rect x="40" y="180" width="150" height="80" rx="14" fill="hsl(26 30% 96%)" stroke="hsl(24 25% 85%)" stroke-width="2" />
    <text x="115" y="215" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="hsl(20 20% 12%)">input</text>
    <text x="115" y="235" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">HUD click</text>
  </g>

  <!-- 2. FSM -->
  <g>
    <rect x="245" y="60" width="150" height="80" rx="14" fill="url(#flowGrad)" stroke="hsl(22 92% 45%)" stroke-width="2" />
    <defs>
      <linearGradient id="flowGrad" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="hsl(22 92% 52%)" />
        <stop offset="100%" stop-color="hsl(36 100% 50%)" />
      </linearGradient>
    </defs>
    <text x="320" y="95" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="800" fill="white">FSM</text>
    <text x="320" y="115" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="white" opacity="0.9">owns time</text>
  </g>

  <!-- 3. State (MobX) -->
  <g>
    <rect x="450" y="60" width="150" height="80" rx="14" fill="hsl(0 0% 100%)" stroke="hsl(24 25% 85%)" stroke-width="2" />
    <text x="525" y="95" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="hsl(20 20% 12%)">state</text>
    <text x="525" y="115" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">MobX stores</text>
  </g>

  <!-- 4. Presenters -->
  <g>
    <rect x="630" y="180" width="150" height="80" rx="14" fill="hsl(0 0% 100%)" stroke="hsl(24 25% 85%)" stroke-width="2" />
    <text x="705" y="215" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="hsl(20 20% 12%)">presenters</text>
    <text x="705" y="235" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">observe → drive</text>
  </g>

  <!-- 5. View (pixi-reels) -->
  <g>
    <rect x="450" y="320" width="150" height="80" rx="14" fill="hsl(26 30% 96%)" stroke="hsl(24 25% 85%)" stroke-width="2" />
    <text x="525" y="355" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="hsl(20 20% 12%)">view</text>
    <text x="525" y="375" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">pixi-reels</text>
  </g>

  <!-- 6. Resolution -->
  <g>
    <rect x="245" y="320" width="150" height="80" rx="14" fill="hsl(26 30% 96%)" stroke="hsl(24 25% 85%)" stroke-width="2" />
    <text x="320" y="355" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="700" fill="hsl(20 20% 12%)">resolution</text>
    <text x="320" y="375" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">allLanded, onComplete</text>
  </g>

  <!-- Arrows -->
  <path d="M 190 200 L 238 130" stroke="hsl(22 92% 52%)" stroke-width="2.5" fill="none" marker-end="url(#flowArrow)" />
  <text x="210" y="170" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">transition</text>

  <path d="M 395 100 L 447 100" stroke="hsl(22 92% 52%)" stroke-width="2.5" fill="none" marker-end="url(#flowArrow)" />
  <text x="421" y="91" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">action</text>

  <path d="M 605 120 Q 665 150 660 178" stroke="hsl(22 92% 52%)" stroke-width="2.5" fill="none" marker-end="url(#flowArrow)" />
  <text x="660" y="140" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">autorun</text>

  <path d="M 680 260 Q 640 300 603 330" stroke="hsl(22 92% 52%)" stroke-width="2.5" fill="none" marker-end="url(#flowArrow)" />
  <text x="665" y="305" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">render</text>

  <path d="M 447 360 L 400 360" stroke="hsl(22 92% 52%)" stroke-width="2.5" fill="none" marker-end="url(#flowArrow)" />
  <text x="423" y="352" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">done</text>

  <path d="M 245 340 Q 160 320 160 260" stroke="hsl(22 92% 52%)" stroke-width="2.5" fill="none" marker-end="url(#flowArrow)" />
  <text x="155" y="300" text-anchor="end" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">next transition</text>

  <!-- Center callout -->
  <text x="410" y="228" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="11" font-weight="700" fill="hsl(22 92% 52%)" letter-spacing="0.1em">
    ONE DIRECTION
  </text>
  <text x="410" y="246" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 10% 40%)">
    no back-channels
  </text>
</svg>
