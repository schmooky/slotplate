---
// Sequence diagram: who calls whom during a spin. Time flows top to bottom.
// 6 actors as vertical lanes.
---
<svg viewBox="0 0 940 680" class="w-full h-auto max-h-[760px]" role="img" aria-label="Spin lifecycle sequence diagram">
  <defs>
    <marker id="seqArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="hsl(22 92% 52%)" />
    </marker>
    <marker id="seqReturn" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="hsl(36 100% 45%)" />
    </marker>
  </defs>

  <!-- Lane headers -->
  {[
    { x: 70, label: 'HUD', sub: 'presenter' },
    { x: 215, label: 'FSM', sub: 'flow' },
    { x: 360, label: 'Balance', sub: 'store' },
    { x: 505, label: 'Reels', sub: 'presenter' },
    { x: 650, label: 'Network', sub: 'infrastructure' },
    { x: 795, label: 'Data', sub: 'store' },
  ].map((a) => (
    <>
      <rect x={a.x - 55} y="20" width="110" height="46" rx="10" fill="hsl(22 92% 52%)" />
      <text x={a.x} y="43" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" font-weight="700" fill="white">{a.label}</text>
      <text x={a.x} y="59" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="9" fill="white" opacity="0.85">{a.sub}</text>
    </>
  ))}

  <!-- Lifelines -->
  {[70, 215, 360, 505, 650, 795].map((x) => (
    <line x1={x} y1="66" x2={x} y2="650" stroke="hsl(24 25% 85%)" stroke-width="1" stroke-dasharray="4,4" />
  ))}

  <!-- 1. User click -->
  <text x="20" y="100" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="700" fill="hsl(20 10% 40%)">user clicks Spin</text>
  <line x1="30" y1="105" x2="62" y2="105" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />

  <!-- 2. HUD -> FSM: transition('spin') -->
  <line x1="70" y1="130" x2="208" y2="130" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="139" y="122" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">transition('spin')</text>

  <!-- 3. FSM -> Balance: debitBet() -->
  <line x1="215" y1="165" x2="353" y2="165" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="284" y="157" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">debitBet()</text>

  <!-- 4. Parallel block -->
  <rect x="180" y="195" width="640" height="95" rx="6" fill="hsl(22 92% 52% / 0.04)" stroke="hsl(22 92% 52% / 0.3)" stroke-dasharray="3,3" />
  <text x="188" y="212" font-family="ui-monospace, Menlo, monospace" font-size="10" font-weight="700" fill="hsl(22 92% 52%)">par [in parallel]</text>

  <!-- 4a. FSM -> Reels: startSpin() -->
  <line x1="215" y1="235" x2="498" y2="235" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="356" y="227" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">startSpin()</text>

  <!-- 4b. FSM -> Network: spin({ bet }) -->
  <line x1="215" y1="268" x2="643" y2="268" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="429" y="260" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">{'spin({ bet })'}</text>

  <!-- 5. Network -> Data: setResponse (returning) -->
  <line x1="650" y1="320" x2="788" y2="320" stroke="hsl(36 100% 45%)" stroke-width="2" stroke-dasharray="5,3" marker-end="url(#seqReturn)" />
  <text x="719" y="312" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(36 100% 35%)">SpinResponse</text>

  <!-- 6. FSM -> FSM: transition('stopSpin') self-loop -->
  <path d="M 215 355 Q 275 345 275 365 Q 275 385 220 385 L 218 385" fill="none" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="295" y="365" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">transition('stopSpin')</text>

  <!-- 7. FSM -> Reels: stopWithResult(grid) -->
  <line x1="215" y1="415" x2="498" y2="415" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="356" y="407" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">stopWithResult(grid)</text>

  <!-- 7a. Reels returns allLanded -->
  <line x1="505" y1="448" x2="222" y2="448" stroke="hsl(36 100% 45%)" stroke-width="2" stroke-dasharray="5,3" marker-end="url(#seqReturn)" />
  <text x="360" y="440" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(36 100% 35%)">allLanded</text>

  <!-- 8. FSM -> FSM: transition('winShow') -->
  <path d="M 215 478 Q 275 468 275 488 Q 275 508 220 508 L 218 508" fill="none" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="295" y="488" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">transition('winShow')</text>

  <!-- 9. FSM -> Reels: showWin(winlines) -->
  <line x1="215" y1="538" x2="498" y2="538" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="356" y="530" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">showWin(winlines)</text>

  <!-- 10. FSM -> Balance: credit(totalWin) -->
  <line x1="215" y1="571" x2="353" y2="571" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="284" y="563" text-anchor="middle" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">credit(totalWin)</text>

  <!-- 11. FSM -> FSM: transition('idle') -->
  <path d="M 215 605 Q 275 595 275 615 Q 275 635 220 635 L 218 635" fill="none" stroke="hsl(22 92% 52%)" stroke-width="2" marker-end="url(#seqArrow)" />
  <text x="295" y="618" font-family="ui-monospace, Menlo, monospace" font-size="10" fill="hsl(20 20% 12%)">transition('idle')</text>

  <!-- Vertical time arrow on left -->
  <line x1="10" y1="90" x2="10" y2="640" stroke="hsl(24 25% 70%)" stroke-width="1" />
  <polygon points="7,635 13,635 10,645" fill="hsl(24 25% 70%)" />
  <text x="18" y="360" font-family="ui-monospace, Menlo, monospace" font-size="9" fill="hsl(20 10% 40%)" transform="rotate(-90 18 360)">time →</text>
</svg>
