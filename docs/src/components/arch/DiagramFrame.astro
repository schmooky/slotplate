---
interface Props {
  title?: string;
  caption?: string;
}
const { title, caption } = Astro.props;
---
<figure class="not-prose my-8">
  {title && (
    <figcaption class="mb-3 flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground">
      <span class="inline-block h-1 w-4 bg-primary rounded-full"></span>
      {title}
    </figcaption>
  )}
  <div class="rounded-2xl border border-border bg-card p-6 overflow-x-auto shadow-sm">
    <slot />
  </div>
  {caption && (
    <figcaption class="mt-3 text-sm text-muted-foreground/90 italic">{caption}</figcaption>
  )}
</figure>
