---
import { SITE } from '../lib/seo';
---
<footer class="mt-24 border-t border-border/60">
  <div class="container grid gap-10 py-10 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-2 font-mono text-sm font-semibold">
        <span class="inline-flex h-6 w-6 items-center justify-center rounded-md bg-gradient-to-br from-primary to-accent text-[10px] text-primary-foreground font-bold">SP</span>
        slotplate
      </div>
      <p class="mt-3 text-sm text-muted-foreground max-w-sm">{SITE.description}</p>
    </div>
    <div>
      <div class="mb-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground/80">Docs</div>
      <ul class="space-y-1.5 text-sm">
        <li><a href="/docs/quickstart/" class="text-muted-foreground hover:text-foreground">Quickstart</a></li>
        <li><a href="/docs/principles/" class="text-muted-foreground hover:text-foreground">Principles</a></li>
        <li><a href="/architecture/" class="text-muted-foreground hover:text-foreground">Architecture</a></li>
        <li><a href="/docs/agents/" class="text-muted-foreground hover:text-foreground">AI agents</a></li>
      </ul>
    </div>
    <div>
      <div class="mb-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground/80">Build</div>
      <ul class="space-y-1.5 text-sm">
        <li><a href="/guides/add-symbol/" class="text-muted-foreground hover:text-foreground">Add a symbol</a></li>
        <li><a href="/guides/add-phase/" class="text-muted-foreground hover:text-foreground">Add a phase</a></li>
        <li><a href="/guides/swap-network/" class="text-muted-foreground hover:text-foreground">Network transport</a></li>
        <li><a href="/guides/spine/" class="text-muted-foreground hover:text-foreground">Spine symbols</a></li>
      </ul>
    </div>
    <div>
      <div class="mb-3 text-[11px] font-semibold uppercase tracking-[0.14em] text-muted-foreground/80">Machine-readable</div>
      <ul class="space-y-1.5 text-sm">
        <li><a href="/llms.txt" class="text-muted-foreground hover:text-foreground">llms.txt</a></li>
        <li><a href="/llms-full.txt" class="text-muted-foreground hover:text-foreground">llms-full.txt</a></li>
        <li><a href={SITE.github} class="text-muted-foreground hover:text-foreground" target="_blank" rel="noopener">GitHub</a></li>
        <li><a href="https://github.com/schmooky/pixi-reels" class="text-muted-foreground hover:text-foreground" target="_blank" rel="noopener">pixi-reels</a></li>
      </ul>
    </div>
  </div>
  <div class="container border-t border-border/40 py-6 text-xs text-muted-foreground/70 flex flex-col md:flex-row justify-between gap-2">
    <div>MIT licensed · Built on <a href="https://github.com/schmooky/pixi-reels" class="text-primary">pixi-reels</a></div>
    <div class="font-mono">© slotplate contributors</div>
  </div>
</footer>
