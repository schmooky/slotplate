---
// Search modal — Pagefind-powered.
//
// Pagefind is a static-site search engine. After `astro build` we run
// `pagefind --site dist` (see package.json `postbuild`) which crawls the
// emitted HTML, builds a binary index in `dist/pagefind/`, and ships
// the matching JS runtime.
//
// The modal is mounted into every page via Base.astro. It's invisible by
// default; opens on `Cmd/Ctrl+K`, focus on the input, or click on the
// nav search button. Esc closes.
//
// Pagefind's UI bundle is loaded lazily on first open so the index ships
// only to users who actually open search.
---
<div
  id="search-modal"
  class="hidden fixed inset-0 z-[100] items-start justify-center bg-background/70 backdrop-blur-sm pt-[10vh] px-4"
  role="dialog"
  aria-modal="true"
  aria-label="Search documentation"
>
  <div class="w-full max-w-2xl rounded-xl border border-border/60 bg-background shadow-2xl shadow-black/40 overflow-hidden">
    <div class="flex items-center gap-3 border-b border-border/40 px-4 py-3">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground" aria-hidden>
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Search docs, guides, patterns…"
        class="flex-1 bg-transparent text-base outline-none placeholder:text-muted-foreground"
        autocomplete="off"
        aria-label="Search query"
      />
      <kbd class="hidden sm:inline-flex h-5 items-center rounded border border-border/60 bg-secondary/40 px-1.5 font-mono text-[10px] text-muted-foreground">Esc</kbd>
    </div>
    <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2">
      <div id="search-empty" class="px-3 py-8 text-center text-sm text-muted-foreground">
        Start typing to search the docs.
      </div>
    </div>
  </div>
</div>

<style>
  #search-modal[data-open='1'] {
    display: flex;
  }
  /* Pagefind result styling — class names come from the runtime. */
  :global(.search-result) {
    display: block;
    border-radius: 0.5rem;
    padding: 0.75rem 0.875rem;
    color: inherit;
    text-decoration: none;
  }
  :global(.search-result:hover),
  :global(.search-result[data-active='1']) {
    background: rgb(var(--secondary) / 0.6);
  }
  :global(.search-result__title) {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.15rem;
  }
  :global(.search-result__excerpt) {
    color: rgb(var(--muted-foreground));
    font-size: 0.8rem;
    line-height: 1.45;
  }
  :global(.search-result__excerpt mark) {
    background: rgb(var(--primary) / 0.25);
    color: inherit;
    padding: 0 0.1rem;
    border-radius: 0.15rem;
  }
</style>

<script>
  // Pagefind runtime is bundled into dist/pagefind/ during postbuild.
  // We resolve the path lazily so dev mode (where the dir doesn't exist
  // yet) doesn't 404.
  type PagefindResult = {
    id: string;
    data: () => Promise<{
      url: string;
      meta: { title: string };
      excerpt: string;
    }>;
  };
  type PagefindAPI = { search: (q: string) => Promise<{ results: PagefindResult[] }> };

  let pagefind: PagefindAPI | null = null;
  let pagefindLoading: Promise<PagefindAPI> | null = null;
  let activeIndex = 0;

  function loadPagefind(): Promise<PagefindAPI> {
    if (pagefind) return Promise.resolve(pagefind);
    if (pagefindLoading) return pagefindLoading;
    pagefindLoading = (async () => {
      // Vite/Astro will refuse to bundle this dynamic import — that's the
      // point. The runtime emits to /pagefind at build time and the
      // browser fetches it at first open.
      const url = `${import.meta.env.BASE_URL ?? '/'}pagefind/pagefind.js`;
      const m = (await import(/* @vite-ignore */ url)) as PagefindAPI;
      pagefind = m;
      return m;
    })();
    return pagefindLoading;
  }

  function open(): void {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    modal.dataset.open = '1';
    modal.style.display = 'flex';
    const input = document.getElementById('search-input') as HTMLInputElement | null;
    requestAnimationFrame(() => input?.focus());
    // Kick off the load.
    loadPagefind().catch(() => {
      const empty = document.getElementById('search-empty');
      if (empty) empty.textContent = 'Search index not available — try `pnpm build` first.';
    });
  }

  function close(): void {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    delete modal.dataset.open;
    modal.style.display = 'none';
  }

  async function runSearch(q: string): Promise<void> {
    const empty = document.getElementById('search-empty');
    const results = document.getElementById('search-results');
    if (!results) return;
    if (!q.trim()) {
      results.innerHTML = '';
      results.appendChild(
        Object.assign(document.createElement('div'), {
          id: 'search-empty',
          className: 'px-3 py-8 text-center text-sm text-muted-foreground',
          textContent: 'Start typing to search the docs.',
        }),
      );
      return;
    }
    if (empty) empty.textContent = 'Searching…';
    try {
      const api = await loadPagefind();
      const search = await api.search(q);
      const items = await Promise.all(search.results.slice(0, 10).map((r) => r.data()));
      activeIndex = 0;
      results.innerHTML = items.length
        ? items
            .map(
              (item, i) => `
                <a class="search-result" href="${item.url}" data-active="${i === 0 ? '1' : '0'}">
                  <div class="search-result__title">${escape(item.meta?.title ?? item.url)}</div>
                  <div class="search-result__excerpt">${item.excerpt}</div>
                </a>
              `,
            )
            .join('')
        : '<div class="px-3 py-8 text-center text-sm text-muted-foreground">No results.</div>';
    } catch (err) {
      results.innerHTML = '<div class="px-3 py-8 text-center text-sm text-muted-foreground">Search unavailable.</div>';
      console.error(err);
    }
  }

  function escape(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
  }

  function moveActive(delta: number): void {
    const items = Array.from(document.querySelectorAll<HTMLAnchorElement>('.search-result'));
    if (items.length === 0) return;
    items[activeIndex]?.removeAttribute('data-active');
    activeIndex = (activeIndex + delta + items.length) % items.length;
    const next = items[activeIndex];
    if (next) {
      next.dataset.active = '1';
      next.scrollIntoView({ block: 'nearest' });
    }
  }

  function activateCurrent(): void {
    const items = document.querySelectorAll<HTMLAnchorElement>('.search-result');
    items[activeIndex]?.click();
  }

  // ─── Wire events ──────────────────────────────────────────────
  document.addEventListener('keydown', (e) => {
    const isToggle = (e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey);
    if (isToggle) {
      e.preventDefault();
      const modal = document.getElementById('search-modal');
      if (modal?.dataset.open === '1') close();
      else open();
      return;
    }
    const modalOpen = document.getElementById('search-modal')?.dataset.open === '1';
    if (!modalOpen) return;
    if (e.key === 'Escape') {
      e.preventDefault();
      close();
    } else if (e.key === 'ArrowDown') {
      e.preventDefault();
      moveActive(1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      moveActive(-1);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      activateCurrent();
    }
  });

  // Close on backdrop click.
  document.getElementById('search-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) close();
  });

  // Wire any nav button with [data-search-trigger].
  document.querySelectorAll<HTMLElement>('[data-search-trigger]').forEach((el) => {
    el.addEventListener('click', open);
  });

  // Live search.
  let searchTimer: ReturnType<typeof setTimeout> | null = null;
  document.getElementById('search-input')?.addEventListener('input', (e) => {
    if (searchTimer) clearTimeout(searchTimer);
    const q = (e.target as HTMLInputElement).value;
    searchTimer = setTimeout(() => runSearch(q), 120);
  });
</script>
