---
import { existsSync, readFileSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import Base from '../layouts/Base.astro';
import { SITE } from '../lib/seo';

// This page renders the repo-root CHANGELOG.md verbatim. The file is
// generated and maintained by Changesets — see .changeset/README.md and
// .github/workflows/release.yml for the publishing flow.

const __filename = fileURLToPath(import.meta.url);
const ROOT = join(dirname(__filename), '..', '..', '..');
const CHANGELOG_PATH = join(ROOT, 'CHANGELOG.md');

let changelog = '';
let hasChangelog = false;
let pkgVersion = '0.0.0';

try {
  const pkg = JSON.parse(readFileSync(join(ROOT, 'package.json'), 'utf8'));
  pkgVersion = pkg.version ?? pkgVersion;
} catch {
  /* swallow — page still renders */
}

if (existsSync(CHANGELOG_PATH)) {
  changelog = readFileSync(CHANGELOG_PATH, 'utf8');
  hasChangelog = true;
}

// Tiny markdown → HTML — keeps the page zero-dep. Headings, lists, code,
// links, bold, italic. The full CHANGELOG markdown is structured this way
// by `@changesets/changelog-github`.
function md(src: string): string {
  // Escape HTML first
  let out = src
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');

  // Code fences ```lang\n...\n```
  out = out.replace(/```(\w*)\n([\s\S]*?)```/g, (_, lang, code) => {
    const cls = lang ? ` class="language-${lang}"` : '';
    return `<pre><code${cls}>${code.replace(/\n$/, '')}</code></pre>`;
  });

  // Inline code `x`
  out = out.replace(/`([^`\n]+)`/g, '<code>$1</code>');

  // Headings
  out = out.replace(/^###### (.*)$/gm, '<h6>$1</h6>');
  out = out.replace(/^##### (.*)$/gm, '<h5>$1</h5>');
  out = out.replace(/^#### (.*)$/gm, '<h4>$1</h4>');
  out = out.replace(/^### (.*)$/gm, '<h3>$1</h3>');
  out = out.replace(/^## (.*)$/gm, '<h2>$1</h2>');
  out = out.replace(/^# (.*)$/gm, '<h1>$1</h1>');

  // Links [text](url)
  out = out.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" rel="noopener">$1</a>');

  // Bold **x**
  out = out.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  // Italic *x*
  out = out.replace(/(^|[^*])\*([^*\n]+)\*/g, '$1<em>$2</em>');

  // Bullet list lines
  out = out.replace(/^(?:- |\* )(.*)$/gm, '<li>$1</li>');
  // Wrap consecutive <li>s into <ul>
  out = out.replace(/(?:<li>[\s\S]*?<\/li>\n?)+/g, (m) => `<ul>${m}</ul>`);

  // Paragraphs — anything not already wrapped
  out = out
    .split(/\n{2,}/)
    .map((para) => {
      const trim = para.trim();
      if (!trim) return '';
      if (/^<(h\d|ul|pre|p)/.test(trim)) return trim;
      return `<p>${trim.replace(/\n/g, ' ')}</p>`;
    })
    .join('\n');

  return out;
}
---
<Base
  title={`Changelog · ${SITE.name}`}
  description="Every release of create-slotplate. Generated by changesets, sourced from CHANGELOG.md."
>
  <div class="container max-w-3xl py-16">
    <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-primary">Releases</div>
    <h1 class="mb-3 text-4xl font-semibold tracking-tight">Changelog</h1>
    <p class="mb-2 text-lg text-muted-foreground">
      Every published version of <code class="rounded bg-secondary px-1.5 py-0.5 text-sm font-mono text-primary">create-slotplate</code>, newest first.
    </p>
    <p class="mb-10 text-sm text-muted-foreground">
      Currently shipping <span class="rounded-md border border-border/60 bg-secondary/40 px-2 py-0.5 font-mono text-xs">v{pkgVersion}</span>.
      Releases are managed by <a class="text-primary underline-offset-4 hover:underline" href="https://github.com/changesets/changesets">Changesets</a> — see <a class="text-primary underline-offset-4 hover:underline" href="https://github.com/schmooky/slotplate/blob/main/.changeset/README.md">how it works</a>.
    </p>

    {hasChangelog ? (
      <article class="prose-docs" set:html={md(changelog)} data-pagefind-body />
    ) : (
      <div class="rounded-lg border border-dashed border-border/60 bg-secondary/30 p-8 text-center">
        <p class="text-base font-medium">No releases yet.</p>
        <p class="mt-1 text-sm text-muted-foreground">
          The first release will appear here as soon as a changeset lands on <code class="rounded bg-secondary px-1.5 py-0.5 font-mono text-xs">main</code>.
        </p>
        <p class="mt-3 text-xs text-muted-foreground">
          Watch <a class="text-primary underline-offset-4 hover:underline" href="https://www.npmjs.com/package/create-slotplate">npm</a>
          and <a class="text-primary underline-offset-4 hover:underline" href="https://github.com/schmooky/slotplate/releases">GitHub Releases</a> for notifications.
        </p>
      </div>
    )}

    <div class="mt-12 border-t border-border/40 pt-6 text-sm text-muted-foreground">
      Spotted something? <a class="text-primary underline-offset-4 hover:underline" href="https://github.com/schmooky/slotplate/blob/main/CHANGELOG.md">Edit the source</a> or <a class="text-primary underline-offset-4 hover:underline" href="https://github.com/schmooky/slotplate/issues/new">open an issue</a>.
    </div>
  </div>
</Base>
