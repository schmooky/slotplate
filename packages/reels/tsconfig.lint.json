{
  "extends": "@slotplate/typescript-config/ts-library.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "target": "ES2021",
    "module": "ESNext",
    "strict": true,
    "strictPropertyInitialization": false,
    "noEmit": false,
    "outDir": "./",
    "rootDir": "./"
  },
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "tests",
    "examples-PIXI7/**/*",
    "examples-PIXI8/**/*",
    "**/*.config.cjs",
    "**/*.mock.js",
    "**/*.config.mts"
  ]
}